# Secrets per-projet (Figma PAT, etc.) — lu par skills/_shared/load-env.sh
.env.snapship
.env.snapship.*

# .snap/ — whitelist manifests + tickets, ignore the rest (caches, queues,
# telemetry, progress, backups, staging galleries — sources of truth are
# the remote platforms).
.snap/*
!.snap/manifests/
!.snap/tickets/

# Migration backups (pre-v1.0.0 snapshots)
.snap.bak-*

# Legacy resolved-config cache (pre-v1.0.0)
.config-resolved.json

# Legacy product cache (pre-v1.0.0)
.claude/product/

# OS junk
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
daemon.log

# Node (if dev tooling added later)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Test artifacts
.bats-tmp/
coverage/

# code-review-graph DB (auto-généré par MCP)
.code-review-graph/
