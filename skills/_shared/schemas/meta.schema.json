{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/BryanBerger98/snapship-plugin/schemas/meta.schema.json",
  "title": "feature meta.json",
  "description": "Métadonnées feature — .claude/product/features/{feature_id}/meta.json. v0.2 — référence PRD archive + mapping domains/journeys impactés (doc fonctionnelle vivante).",
  "type": "object",
  "required": ["feature_id", "feature_name", "state", "created_at"],
  "additionalProperties": false,
  "properties": {
    "feature_id": {
      "type": "string",
      "pattern": "^[0-9]{2}-[a-z0-9][a-z0-9-]*$",
      "description": "Format NN-kebab (ex: 01-auth)"
    },
    "feature_name": {
      "type": "string",
      "minLength": 1
    },
    "state": {
      "type": "string",
      "enum": ["defined", "ticketed", "wireframed", "developed", "qa-validated"]
    },
    "priority": {
      "type": "string",
      "enum": ["must", "should", "could", "wont"]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "lang": {
      "type": "string",
      "enum": ["fr", "en"]
    },
    "green_field": {
      "type": "boolean",
      "description": "True si feature créée projet vide (pas de codebase existant)"
    },
    "domains": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9-]*$"
      },
      "uniqueItems": true,
      "description": "Slugs domaines impactés par la feature (ex: ['auth', 'dashboard']). Référence domains.json."
    },
    "impacted_journeys": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["domain", "journey_slug"],
        "properties": {
          "domain": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "journey_slug": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          }
        }
      },
      "uniqueItems": true,
      "description": "User journeys impactés (cible doc fonctionnelle vivante /snap:doc-update post-ship)."
    },
    "prd": {
      "type": "object",
      "additionalProperties": false,
      "description": "Page PRD archive (immuable post-ship). Path: {prd_root}/{YYYY}/{MM-YYYY}/{NN-feature}.",
      "properties": {
        "page_id": {
          "type": "string",
          "description": "ID page PRD plateforme doc (AFFiNE/Notion)"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "path": {
          "type": "string",
          "description": "Chemin date-based ex: 'Change Requests/2026/05-2026/01-bouton-login'"
        }
      }
    },
    "branch_name": {
      "type": "string",
      "description": "Branche git créée par /develop step-02 (idempotent)"
    },
    "preview_url": {
      "type": "string",
      "format": "uri",
      "description": "URL preview pour /qa wireframe_check Playwright"
    },
    "platform": {
      "type": "string",
      "enum": ["github", "gitlab", "jira"],
      "description": "Plateforme tickets pour cette feature (cache pour résolution rapide)"
    },
    "epic_link": {
      "type": "string",
      "description": "Optionnel — lien parent epic (JIRA epic key, GH milestone, etc.)"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "retry_count": {
      "type": "integer",
      "minimum": 0,
      "description": "Compteur retries fail_strategy=retry sur cette feature"
    }
  }
}
