{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/BryanBerger98/snapship-plugin/schemas/config.schema.json",
  "title": "snapship.config.json",
  "description": "Configuration projet snap — racine projet, committable, partagée équipe.",
  "type": "object",
  "required": ["version"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+(\\.\\d+)?$",
      "description": "Schema version (semver). Major bump = breaking change."
    },
    "repository": { "$ref": "#/$defs/repository" },
    "tickets": { "$ref": "#/$defs/tickets" },
    "documentation": { "$ref": "#/$defs/documentation" },
    "wireframes": { "$ref": "#/$defs/wireframes" },
    "design": { "$ref": "#/$defs/design" },
    "testing": { "$ref": "#/$defs/testing" },
    "naming": { "$ref": "#/$defs/naming" },
    "ai": { "$ref": "#/$defs/ai" },
    "develop": { "$ref": "#/$defs/develop" },
    "qa": { "$ref": "#/$defs/qa" },
    "lifecycle_scripts": { "$ref": "#/$defs/lifecycle_scripts" },
    "templates": { "$ref": "#/$defs/templates" },
    "defaults": { "$ref": "#/$defs/defaults" }
  },
  "$defs": {
    "severity": {
      "type": "string",
      "enum": ["info", "minor", "major", "critical"]
    },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["platform"],
      "properties": {
        "platform": {
          "type": "string",
          "enum": ["github", "gitlab"]
        },
        "http_url": { "type": "string", "format": "uri" },
        "ssh_url": { "type": "string" },
        "default_branch": { "type": "string", "default": "main" },
        "protected_branches": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["main"]
        }
      }
    },
    "tickets": {
      "type": "object",
      "additionalProperties": false,
      "required": ["platform"],
      "properties": {
        "platform": {
          "type": "string",
          "enum": ["github", "gitlab", "jira", "inherit"]
        },
        "url": { "type": "string", "format": "uri" },
        "default_labels": {
          "type": "array",
          "items": { "type": "string" }
        },
        "jira": {
          "type": "object",
          "additionalProperties": false,
          "description": "Utilisé seulement si platform=jira",
          "properties": {
            "project_key": {
              "type": "string",
              "pattern": "^[A-Z][A-Z0-9_]*$"
            },
            "default_issue_type": {
              "type": "string",
              "default": "Story"
            },
            "workflow_states": {
              "type": "object",
              "additionalProperties": { "type": "string" },
              "properties": {
                "todo": { "type": "string" },
                "in_progress": { "type": "string" },
                "review": { "type": "string" },
                "done": { "type": "string" }
              }
            },
            "transitions": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            }
          }
        }
      }
    },
    "documentation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["platform"],
      "properties": {
        "platform": {
          "type": "string",
          "enum": ["affine", "notion", "none"]
        },
        "url": { "type": "string", "format": "uri" },
        "workspace": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "id": { "type": "string" },
            "root_page_id": { "type": "string" }
          }
        },
        "paths": {
          "type": "object",
          "additionalProperties": false,
          "description": "Racines AFFiNE/Notion pour hiérarchie v0.2 (functional vivante + PRD archive).",
          "properties": {
            "functional_root": {
              "type": "string",
              "default": "Product Docs",
              "description": "Page racine doc fonctionnelle vivante (hiérarchie domain → user journey)."
            },
            "prd_root": {
              "type": "string",
              "default": "Change Requests",
              "description": "Page racine archive PRD (path date-based: {prd_root}/{YYYY}/{MM-YYYY}/{NN-feature})."
            }
          }
        },
        "auto_update_mode": {
          "type": "string",
          "enum": ["diff", "rewrite"],
          "default": "diff",
          "description": "Mode update doc fonctionnelle post-ship via /snap:doc-update. diff=patch sections impactées. rewrite=regenerate full journey."
        },
        "auto_update_on_qa_success": {
          "type": "boolean",
          "default": true,
          "description": "Trigger auto /snap:doc-update quand /snap:qa valide une feature (state=qa-validated)."
        },
        "templates": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "Page IDs (AFFiNE/Notion) of pre-pushed doc templates. Distinct from top-level `templates` which override bundled markdown.",
          "properties": {
            "prd_feature": { "type": "string" },
            "wireframes_gallery": { "type": "string" }
          }
        },
        "auto_publish": { "type": "boolean", "default": true },
        "page_naming": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "properties": {
            "prd_feature": { "type": "string" },
            "wireframes_gallery": { "type": "string" }
          }
        }
      }
    },
    "wireframes": {
      "type": "object",
      "additionalProperties": false,
      "description": "Configuration skill /wireframe. Blocs platform-specific (`frame0`, `penpot`, `figma`) consultés selon `platform`.",
      "properties": {
        "platform": {
          "type": "string",
          "enum": ["frame0", "penpot", "figma"],
          "default": "frame0"
        },
        "export_format": {
          "type": "string",
          "enum": ["png", "svg", "pdf"],
          "default": "png"
        },
        "export_scale": {
          "type": "integer",
          "enum": [1, 2, 3],
          "default": 2
        },
        "naming_pattern": {
          "type": "string",
          "default": "{feature_id}-{screen_name}"
        },
        "frame0": {
          "type": "object",
          "additionalProperties": false,
          "description": "Utilisé seulement si platform=frame0",
          "properties": {
            "api_port": {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535,
              "default": 58320,
              "description": "Port API HTTP locale Frame0 Desktop. L'action `export-png` court-circuite MCP et POST `file:export-image` ici. Override seulement si Frame0 lancé avec --api-port=<N>."
            },
            "export_source_dir": {
              "type": "string",
              "description": "Chemin absolu où Frame0 Desktop écrit les exports avant que le helper ne les déplace vers la destination feature. Par défaut résolu runtime (cwd Frame0)."
            }
          }
        },
        "penpot": {
          "type": "object",
          "additionalProperties": false,
          "description": "Utilisé seulement si platform=penpot",
          "properties": {
            "export_dir": {
              "type": "string",
              "description": "Chemin absolu où Penpot MCP écrit les assets exportés PNG/SVG. L'outil Penpot `export_shape` requiert un filePath absolu. Défaut `{project_root}/.claude/product/features/{feature_id}/wireframes/` résolu runtime."
            },
            "file_id": {
              "type": "string",
              "description": "UUID fichier Penpot ciblé par le projet. Quand défini, /wireframe step-00 vérifie `penpot.currentFile.id` contre cette valeur et halt avec message clair si l'utilisateur a le mauvais fichier ouvert dans l'onglet navigateur Penpot. Penpot MCP ne peut pas ouvrir de fichier par programme — utilisateur doit naviguer manuellement."
            },
            "file_name": {
              "type": "string",
              "description": "Nom de fichier lisible affiché dans l'erreur de mismatch (informationnel ; pas utilisé pour matching)."
            }
          }
        },
        "figma": {
          "type": "object",
          "additionalProperties": false,
          "description": "Utilisé seulement si platform=figma. Serveur MCP cible: figma-console-mcp (southleft).",
          "properties": {
            "file_key": {
              "type": "string",
              "description": "Clé fichier Figma ciblée par le projet. Quand définie, /wireframe step-00 vérifie `figma_get_current_file` contre cette valeur et halt si fichier différent ouvert dans Figma Desktop."
            },
            "file_name": {
              "type": "string",
              "description": "Nom de fichier lisible affiché dans l'erreur de mismatch (informationnel)."
            },
            "token_env": {
              "type": "string",
              "default": "FIGMA_ACCESS_TOKEN",
              "description": "Nom variable env où chercher le token API Figma personnel. Le helper vérifie présence avant invocation MCP."
            }
          }
        }
      }
    },
    "design": {
      "type": "object",
      "additionalProperties": false,
      "description": "Configuration skill /design. Optionnel — section absente = skill désactivé. Blocs platform-specific consultés selon `platform`.",
      "properties": {
        "platform": {
          "type": "string",
          "enum": ["penpot", "figma"],
          "description": "Plateforme cible pour maquettes haute-fidélité. Frame0 exclu (low-fi seulement)."
        },
        "export_format": {
          "type": "string",
          "enum": ["png", "svg", "pdf"],
          "default": "png"
        },
        "naming_pattern": {
          "type": "string",
          "default": "{feature_id}-{screen_name}-design"
        },
        "mode_defaults": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "mockup_canvas": {
              "type": "string",
              "enum": ["mobile-portrait", "mobile-landscape", "desktop", "tablet"],
              "default": "mobile-portrait"
            },
            "design_system_source": {
              "type": "string",
              "enum": ["auto", "file", "none"],
              "default": "auto",
              "description": "auto=détection (file présent → file, sinon none). file=lit système design fichier configuré. none=mockup libre sans contrainte."
            }
          }
        },
        "penpot": {
          "type": "object",
          "additionalProperties": false,
          "description": "Utilisé seulement si platform=penpot. Helper réutilisé: penpot-helper.sh.",
          "properties": {
            "file_id": { "type": "string" },
            "file_name": { "type": "string" },
            "export_dir": { "type": "string" },
            "design_system_page": {
              "type": "string",
              "default": "Components",
              "description": "Nom page Penpot où le système design est stocké (composants, tokens). Lu en référence visuelle pour les mockups — /design n'écrit jamais dans le DS."
            }
          }
        },
        "figma": {
          "type": "object",
          "additionalProperties": false,
          "description": "Utilisé seulement si platform=figma. Helper: figma-helper.sh — même helper et même plugin Desktop Bridge que /wireframe figma.",
          "properties": {
            "file_key": { "type": "string" },
            "file_name": { "type": "string" },
            "token_env": {
              "type": "string",
              "default": "FIGMA_ACCESS_TOKEN"
            }
          }
        }
      }
    },
    "testing": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "test_command": { "type": "string" },
        "typecheck_command": { "type": "string" },
        "lint_command": { "type": "string" },
        "format_command": { "type": "string" }
      }
    },
    "naming": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "feature_slug_max_length": {
          "type": "integer",
          "minimum": 10,
          "maximum": 100,
          "default": 40
        },
        "branch_pattern": {
          "type": "string",
          "default": "{type}/{ticket_id}-{slug}"
        },
        "commit_pattern": {
          "type": "string",
          "default": "{type}({scope}): {message}"
        },
        "ticket_id_regex": { "type": "string" }
      }
    },
    "ai": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_parallel_agents": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10,
          "default": 5
        },
        "mcp_servers_required": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "mcp_servers_optional": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        }
      }
    },
    "develop": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "review_cycles_max": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10,
          "default": 3
        },
        "auto_apply_review_feedback": {
          "type": "boolean",
          "default": true
        },
        "fail_strategy": {
          "type": "string",
          "enum": ["next-ticket", "stop", "retry"],
          "default": "next-ticket"
        },
        "reviews": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "technical": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "severity_threshold": { "$ref": "#/$defs/severity" }
              }
            },
            "functional": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "severity_threshold": { "$ref": "#/$defs/severity" }
              }
            },
            "security": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "severity_threshold": { "$ref": "#/$defs/severity" }
              }
            }
          }
        }
      }
    },
    "qa": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "qa_cycles_max": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10,
          "default": 2
        },
        "auto_apply_qa_feedback": {
          "type": "boolean",
          "default": true
        },
        "severity_threshold": { "$ref": "#/$defs/severity" },
        "retrigger_review": {
          "type": "boolean",
          "default": false
        },
        "regression": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean", "default": true },
            "scope": {
              "type": "string",
              "enum": ["impacted", "full", "tests-only"],
              "default": "impacted"
            }
          }
        },
        "wireframe_check": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean", "default": false },
            "mode": {
              "type": "string",
              "enum": ["playwright"],
              "default": "playwright"
            },
            "diff_threshold_pct": {
              "type": "number",
              "minimum": 0,
              "maximum": 100,
              "default": 5
            },
            "severity_on_mismatch": { "$ref": "#/$defs/severity" }
          }
        },
        "design_check": {
          "type": "object",
          "additionalProperties": false,
          "description": "Vérification parité maquette hi-fi vs implémentation (skill /design). Opt-in.",
          "properties": {
            "enabled": { "type": "boolean", "default": false },
            "mode": {
              "type": "string",
              "enum": ["asset-presence", "playwright"],
              "default": "asset-presence",
              "description": "asset-presence = vérifie juste que l'asset design existe sur disque. playwright = diff visuel hi-fi (futur)."
            },
            "diff_threshold_pct": {
              "type": "number",
              "minimum": 0,
              "maximum": 100,
              "default": 5
            },
            "severity_on_mismatch": { "$ref": "#/$defs/severity" }
          }
        }
      }
    },
    "lifecycle_scripts": {
      "type": "object",
      "additionalProperties": false,
      "description": "Scripts custom workflow (≠ hooks Claude Code natifs). Path script exécutable.",
      "properties": {
        "pre_define": { "type": "string" },
        "post_define": { "type": "string" },
        "pre_ticket": { "type": "string" },
        "post_ticket": { "type": "string" },
        "pre_wireframe": { "type": "string" },
        "post_wireframe": { "type": "string" },
        "pre_design": { "type": "string" },
        "post_design": { "type": "string" },
        "pre_develop": { "type": "string" },
        "post_develop": { "type": "string" },
        "pre_qa": { "type": "string" },
        "post_qa": { "type": "string" }
      }
    },
    "templates": {
      "type": "object",
      "additionalProperties": false,
      "description": "Template resolution. Order: explicit override path > repo-native (.github/.gitlab) > bundled default in skills/_shared/templates/. Override paths are relative to project root (or absolute).",
      "properties": {
        "use_repo_native": {
          "type": "boolean",
          "default": true,
          "description": "When true (default), reuse host-native markdown templates found under .github/.gitlab (issue templates, PULL_REQUEST_TEMPLATE) before falling back to bundled defaults. Explicit override paths below always win. Set false to ignore repo-native templates entirely."
        },
        "tickets": {
          "type": "object",
          "additionalProperties": false,
          "description": "Per-ticket-type overrides. Each key resolves against `tickets.platform` to pick the file.",
          "properties": {
            "user_story": { "type": ["string", "null"], "default": null },
            "bug":        { "type": ["string", "null"], "default": null },
            "epic":       { "type": ["string", "null"], "default": null }
          }
        },
        "pr": {
          "type": ["string", "null"],
          "default": null,
          "description": "Override PR/MR body template. Resolved against `repository.platform` (github|gitlab) when null. Replaces legacy `repository.pr_template_path`."
        },
        "review_thread": {
          "type": ["string", "null"],
          "default": null,
          "description": "Override template posted as PR/MR/ticket comment by /develop after each review cycle."
        },
        "aggregated_feedback": {
          "type": ["string", "null"],
          "default": null,
          "description": "Override internal markdown blob consumed by the dev agent during /develop Phase 2 fix loop."
        }
      }
    },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "lang": {
          "type": "string",
          "enum": ["fr", "en"],
          "default": "fr"
        },
        "auto_mode": { "type": "boolean", "default": false },
        "save_mode": { "type": "boolean", "default": true },
        "branch_mode": { "type": "boolean", "default": true },
        "economy_mode": { "type": "boolean", "default": false }
      }
    }
  }
}
